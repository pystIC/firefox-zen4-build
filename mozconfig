ac_add_options --enable-application=browser

# Clang-cl flag syntax: -clang: prefix required on Windows for GCC-style flags
ac_add_options --enable-optimize="-O3 -clang:-march=znver4"

# Cross-language LTO (C++ <-> Rust): Mozilla's recommended mode for release builds
ac_add_options --enable-lto=cross

# Release mode (enables additional release-only optimizations)
ac_add_options --enable-release
ac_add_options --disable-debug
ac_add_options --disable-debug-symbols

# PGO: must use mk_add_options, not ac_add_options
mk_add_options MOZ_PGO=1
export MOZ_PGO_OPTIMIZE_FLAGS="-O3 -clang:-march=znver4 -fprofile-use -fprofile-correction"

# Limit parallelism during PGO+LTO link to avoid OOM on 32GB
mk_add_options MOZ_MAKE_FLAGS=-j4

# Rust: target Zen 4, max optimization, single codegen unit for LTO
export RUSTFLAGS="-C target-cpu=znver4 -C opt-level=3 -C codegen-units=1"

# Disable unused subsystems (smaller binary, fewer indirect calls)
ac_add_options --disable-crashreporter
ac_add_options --disable-updater
ac_add_options --disable-maintenance-service
ac_add_options --disable-webrtc
ac_add_options --disable-tests
ac_add_options --disable-accessibility
ac_add_options --disable-stl-hardening
