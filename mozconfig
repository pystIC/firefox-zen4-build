ac_add_options --enable-application=browser
ac_add_options --enable-optimize="-O3 /arch:AVX512"
ac_add_options --enable-lto=full
ac_add_options MOZ_PGO=1
ac_add_options MOZ_PGO_OPTIMIZE_FLAGS="/arch:AVX512 -fprofile-use -fprofile-correction"

# Rust optimizations (more aggressive)
export RUSTFLAGS="-C target-cpu=znver4 -C opt-level=3 -C codegen-units=1"
ac_add_options RUSTC_OPT_LEVEL=3
ac_add_options CARGO_PROFILE_RELEASE_LTO=true

# Disable telemetry and background components
ac_add_options --disable-crashreporter
ac_add_options --disable-updater
ac_add_options --disable-maintenance-service
ac_add_options --disable-webrtc

